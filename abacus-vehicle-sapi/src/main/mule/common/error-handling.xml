    <error-handler name="abacus-error-handler" doc:id="fe1cdbb5-5e65-447c-aded-96944414f88e" >
					<on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="376d3b65-3484-4ef2-93cf-9ed89879fad1" when="#[!(['SERVICE_UNAVAILABLE','TIMEOUT','CONNECTIVITY'] contains error.errorType.identifier)]">
				
					<set-variable value="#[true]" doc:name="Set isFailure variable" doc:id="e91743d7-e008-4870-8e38-dc2d8348bfc8" variableName="isFailure" />
					<ee:transform doc:name="Capture error object" doc:id="c100b694-1bcb-4c93-8ae2-82537a91fdad">
					<ee:message>
					</ee:message>
					<ee:variables>
					<ee:set-variable variableName="errorObject" ><![CDATA[%dw 2.0
output application/json
---
error]]></ee:set-variable>
					</ee:variables>
				</ee:transform>
				
					</on-error-continue>
	</error-handler>
    
	<sub-flow name="global-prepare-error-response-sub-flow" doc:id="144512c8-8979-4ad1-ad6e-4daef8496754">
		<ee:transform doc:name="Compose Error Payload" doc:id="a9224e8d-d3a4-47b4-9230-a946a8f49650">
			<ee:message>
				<ee:set-payload resource="dataweaves/p-build-error-response.dwl" />
			</ee:message>
		</ee:transform>
        <logger level="ERROR" doc:name="Log Error" doc:id="04e30967-b2b6-4f8d-a292-167a4f0caadc" message="#[&quot;\'Transaction\': &quot; ++ correlationId ++ &quot; \'Error Payload\': &quot;] #[payload]"/>
    </sub-flow>
	<error-handler name="mq-error-handler" doc:id="c5bf6a20-564b-4505-8feb-19ecf13e032d" >
		<on-error-propagate enableNotifications="true" logException="true" doc:name="Continue-On-Retriable-Errors" doc:id="d4b50287-962d-4616-915d-7a46ff529e71" type="SALESFORCE-COMPOSITE:CONNECTIVITY,SALESFORCE-COMPOSITE:TRANSACTION, SALESFORCE-COMPOSITE:TRANSFORMATION, SALESFORCE-COMPOSITE:UNKNOWN, SALESFORCE-COMPOSITE:VALIDATION, STREAM_MAXIMUM_SIZE_EXCEEDED">
			<logger level="ERROR" doc:name="Log Retriable Error" doc:id="8a473440-c6b8-498e-aeff-e00ee88b5ce1" message="#[&quot;\'Transaction\': &quot; ++ correlationId ++ &quot;\'QuoteId\': &quot; ++ (vars.quoteId default &quot;&quot;) ++ &quot;\'Error\': &quot; ++ error.description]"/>
			<anypoint-mq:nack doc:name="Nack to send to original queue" doc:id="98dcb96d-d364-4666-b98a-70ce0f834dc7" config-ref="Anypoint_MQ_Config" ackToken="#[vars.ackToken]" />
		</on-error-propagate>
		<on-error-continue enableNotifications="true" logException="true" doc:name="Other Errors" doc:id="87d2d7ce-c8a8-47eb-afed-0fbfb96c1095" type="ANY">
			<logger level="ERROR" doc:name="Log Non Retriable Errors" doc:id="63c3fcad-6ac3-428f-be68-ec4b83e5fca4" message="#[output application/java&#10;---&#10;&quot;\'Transaction\': &quot; ++ correlationId ++ &quot;\'QuoteId\': &quot; ++ (vars.quoteId default &quot;&quot;)&#10;     ++ &quot;\'errorDescription\':&quot; ++ (vars.errorMessage default error.description)]" />
			<set-variable value="#[vars.ackToken default attributes.ackToken]" doc:name="Set ACK Variable" doc:id="c45ac45a-cb45-48f7-b0d0-609cbe3fdcf6" variableName="acknowledgeToken"/>
			<anypoint-mq:publish doc:name="Publish To DLQ" doc:id="7ea89802-e8d9-4ac3-8bbf-6dc1e192fea0" config-ref="Anypoint_MQ_Config" destination="${mq.dlq}">
				<anypoint-mq:body><![CDATA[#[%dw 2.0
output application/json
---
{
	"originalPayload": vars.origPayload default payload,
	"errorMessage": error.detailedDescription as String
}]]]></anypoint-mq:body>
				<anypoint-mq:properties><![CDATA[#[{
	"correlationId" : attributes.properties.correlationId default correlationId,
	"quoteId": vars.quoteId default attributes.properties.quoteId
}]]]></anypoint-mq:properties>
			</anypoint-mq:publish>
			<anypoint-mq:ack doc:name="Ack the Original Message" doc:id="d1b5061c-09c9-4f05-acf4-115f4a52e539" config-ref="Anypoint_MQ_Config" ackToken="#[vars.acknowledgeToken]"/>
		</on-error-continue>
	</error-handler>
	
	</mule>
