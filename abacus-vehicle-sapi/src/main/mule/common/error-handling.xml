		<on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="8b9120d9-71d2-49dd-be4f-43fd0dcc1288" when='#[error.errorType.namespace == "VALIDATION"]'>
			<ee:transform doc:name="Set Error Variables" doc:id="75069714-774c-4148-8355-f5da19acf599">
				<ee:message />
				<ee:variables>
					<ee:set-variable variableName="httpStatus"><![CDATA[%dw 2.0
output application/java
var isGatewayError = (p('abacus.systemErrorCodes') splitBy ",") contains (vars.errorObject.errorMessage.attributes.statusCode as String) default false
---
if(isGatewayError)
vars.errorObject.errorMessage.attributes.statusCode

else if(vars.errorObject != null)
	if(!isEmpty(vars.errorObject.errorMessage.payload.errors[0].errorCode)) 
		400
	else 
		vars.errorObject.errorMessage.attributes.statusCode default 400
else
400]]></ee:set-variable>
					<ee:set-variable variableName="errorCode"><![CDATA[%dw 2.0
output application/java
---
if(vars.errorObject != null)
    (vars.errorObject.errorType.identifier)
else
    null]]></ee:set-variable>
					<ee:set-variable variableName="errorDescription"><![CDATA[%dw 2.0
output application/java
var isGatewayError = (p('abacus.systemErrorCodes') splitBy ",") contains (vars.errorObject.errorMessage.attributes.statusCode as String) default false
---
if (isGatewayError)
p('abacus.error.' ++ vars.errorObject.errorMessage.attributes.statusCode) default vars.errorObject.description

else if( !isEmpty(vars.errorObject.errorMessage.payload) )
(vars.errorObject.errorMessage.payload.errors[0].title) default vars.errorObject.errorMessage.payload.title

else
null]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="e0a39e3b-3af6-443c-9259-bc4205a5ee36" name="global-prepare-error-response-sub-flow" />
		</on-error-continue>
		<!-- If none of the above matches then handle a the exception using generic handler -->
