						attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload
						value="#[%dw 2.0 output application/json --- readUrl('classpath://samples/new-business-event-details-from-alfa-sapi-mock-response.json', 'application/json')]"
