		<http:request method="POST" doc:name="Person Fraud Check C5 Request" doc:id="6a07a831-e52d-4d00-83bb-21b2bed60474" config-ref="HTTP_LoMapi_Request_configuration" path="${lomapi.personFraudCheck.path}" >
